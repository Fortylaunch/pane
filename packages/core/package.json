{
  "name": "@pane/core",
  "version": "0.0.1",
  "description": "Core system — spec types, modality, agents, actions, interaction, feedback, runtime",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "publishConfig": { "access": "public" },
  "exports": {
